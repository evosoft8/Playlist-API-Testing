              "});",
              "",
              "// Content-Type header",
              "pm.test(\"Content-Type is application/json\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "// JSON body",
              "pm.test(\"Response body is valid JSON\", function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "// Response is an array (search results)",
              "pm.test(\"Response body is an array\", function () {",
              "    const jsonData = pm.response.json();",
              "    const results = Array.isArray(jsonData) ? jsonData : (jsonData.results || jsonData.data || jsonData.playlists);",
              "    pm.expect(results).to.be.an(\"array\");",
              "});",
              "",
              "// Validate schema of each result (if any)",
              "pm.test(\"Each result has required playlist fields\", function () {",
              "    const jsonData = pm.response.json();",
              "    const results = Array.isArray(jsonData) ? jsonData : (jsonData.results || jsonData.data || jsonData.playlists || []);",
              "    results.forEach(item => {",
              "        pm.expect(item).to.have.property(\"id\").that.is.a(\"string\");",
              "        pm.expect(item).to.have.property(\"name\").that.is.a(\"string\");",
              "        pm.expect(item).to.have.property(\"songs\").that.is.an(\"array\");",
              "        pm.expect(item).to.have.property(\"tags\").that.is.an(\"array\");",
              "    });",
              "});",
              "",
              "// Pagination respects limit",
              "pm.test(\"Result count does not exceed limit query param\", function () {",
              "    const jsonData = pm.response.json();",
              "    const results = Array.isArray(jsonData) ? jsonData : (jsonData.results || jsonData.data || jsonData.playlists || []);",
              "    const limit = parseInt(pm.request.url.query.get(\"limit\") || \"25\", 10);",
              "    pm.expect(results.length).to.be.at.most(limit);",
              "});"
            ]
          }
        }
