              "// 3. Response body is JSON",
              "pm.test(\"Response body is JSON\", function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "// 4. Response has an `id` field (string)",
              "pm.test(\"Response has an 'id' field (string)\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"id\");",
              "    pm.expect(jsonData.id).to.be.a(\"string\");",
              "});",
              "",
              "// 5. Response `name` equals \"My playlist\"",
              "pm.test(\"Response 'name' equals 'My playlist'\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.name).to.eql(\"My playlist\");",
              "});",
              "",
              "// 6. Response `description` equals \"A list of the best songs in the universe\"",
              "pm.test(\"Response 'description' equals 'A list of the best songs in the universe'\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.description).to.eql(\"A list of the best songs in the universe\");",
              "});",
              "",
              "// 7. Response `songs` is an array with 5 items",
              "pm.test(\"Response 'songs' is an array with 5 items\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.songs).to.be.an(\"array\").with.lengthOf(5);",
              "});",
              "",
              "// 8. Response `tags` is an array",
              "pm.test(\"Response 'tags' is an array\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.tags).to.be.an(\"array\");",
              "});",
              "",
              "// 9. Save `id` from response into collection variable `playlistId`",
              "pm.test(\"Save 'id' to collection variable 'playlistId'\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.id).to.be.a(\"string\");",
              "    pm.collectionVariables.set(\"playlistId\", jsonData.id);",
              "});",
