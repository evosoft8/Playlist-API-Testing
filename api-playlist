            "type": "text/javascript",
            "exec": [
              "// Status code validation (accept 200 or 204)",
              "pm.test(\"Status code is 200 or 204\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
              "});",
              "",
              "// Response time",
              "pm.test(\"Response time is below 3000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});",
              "",
              "// If there is a body, validate schema",
              "pm.test(\"Response body (if present) matches updated playlist schema\", function () {",
              "    if (pm.response.code === 204 || !pm.response.text()) {",
              "        pm.expect(true).to.be.true; // no body expected",
              "        return;",
              "    }",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"id\").that.is.a(\"string\");",
              "    pm.expect(jsonData).to.have.property(\"name\").that.is.a(\"string\");",
              "    pm.expect(jsonData).to.have.property(\"description\").that.is.a(\"string\");",
              "    pm.expect(jsonData).to.have.property(\"songs\").that.is.an(\"array\");",
              "    pm.expect(jsonData).to.have.property(\"tags\").that.is.an(\"array\");",
              "});",
              "",
              "// Tags in response include the tags sent (when body present)",
              "pm.test(\"Updated tags include '2024', 'space', 'blastoff'\", function () {",
              "    if (pm.response.code === 204 || !pm.response.text()) {",
              "        pm.expect(true).to.be.true;",
              "        return;",
              "    }",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.tags).to.include.members([\"2024\", \"space\", \"blastoff\"]);",
              "});"
            ]
          }
        }
