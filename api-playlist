              "// 1. Status code is 201 (Created)",
              "pm.test(\"Status code is 201 (Created)\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "// 2. Response time is below 3000ms",
              "pm.test(\"Response time is below 3000ms\", function () {",
